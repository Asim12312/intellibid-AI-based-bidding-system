{
  "name": "intellibid-monorepo",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev:all",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev:all": "npx concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "seed:admin": "npm run seed:admin --workspace=server",
    "build": "npm run build --workspace=client"
  },
  "dependencies": {
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}